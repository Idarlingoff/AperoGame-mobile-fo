{
  "rules": {
    "gameCodes": {
      "$code": { ".read": "auth != null", ".write": "auth != null" }
    },
    "games": {
      "$gameId": { ".read": "auth != null", ".write": "auth != null" }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}